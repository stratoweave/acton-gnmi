import testing

from proto import Notification, Update, Path, PathElem
from proto import StringValue, DoubleValue, LeafListValue, BoolValue
from gnyang.gnmi import from_gnmi_notif, select_notif_matches, select_notif_paths

import yang
import yang.gdata as ygdata
import yang.schema as yschema

from yang.data import YangValidationError
from yang.identityref import Identityref, PartialIdentityref
from yang.type import Decimal, Ranges

def _test_select_notif_paths():

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    select_notif_paths(notif_in, 'c1')

def _test_select_notif_matches():

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0)
                            ],
                           [Path([PathElem('c1', []), PathElem('l1', [])], '', '')], False)

    updates, deletes = select_notif_matches(notif_in, 'c1')
    testing.assertEqual(len(updates), 2)
    testing.assertEqual(len(deletes), 1)
    testing.assertEqual(updates[0].elem, PathElem('c1', []))
    testing.assertEqual(updates[0].update.path, Path([PathElem('l1', [])], '', ''))
    testing.assertEqual(deletes[0].elem, PathElem('c1', []))
    testing.assertEqual(deletes[0].delete, Path([PathElem('l1', [])], '', ''))

def _test_y1_gnmi_take_container():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c1 {
    description "Container 1";
    leaf l1 {
      type string;
      description "Leaf 1";
    }
    list l2 {
      key "k1";
      leaf k1 {
        type string;
        description "Key 1";
      }
      leaf v1 {
        type string;
        description "Value 1";
      }
    }
    leaf lrf2 {
      type leafref {
        path "/c1/l2/k1";
      }
    }
    leaf-list ll1 {
      type string;
      description "Leaf List 1";
    }
    leaf-list ll3 {
      type decimal64 {
        fraction-digits 2;
      }
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yschema.DRoot):
        for child in s.children:
            if child.name == 'c1':
                if isinstance(child, yschema.DContainer):
                    notif_in.take_container(child, 'c1', False, [])
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_list():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  list l2 {
    key "k1";
    leaf k1 {
      type string;
      description "Key 1";
    }
    leaf v1 {
      type string;
      description "Value 1";
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                            [
                            Update(Path([PathElem('l2', [('k1', 'Key 1')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('l2', [('k1', 'Key 1')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yschema.DRoot):
        c1_opval: ?(op: ?str, val: ?value) = None
        c1_schema: ?yschema.DContainer = None

        for child in s.children:
            if child.name == 'l2':
                if isinstance(child, yschema.DList):
                    list_val = notif_in.take_list(child, 'l2', False, [])
                    testing.assertEqual(len(list_val), 1)
                    list_notif = list_val[0].val
                    if isinstance(list_notif, Notification):
                        testing.assertEqual(list_notif.prefix, Path([PathElem('l2', [('k1', 'Key 1')])], '', ''))
                        testing.assertEqual(len(list_notif.update), 2)
                    else:
                        raise Exception()
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_leaflist():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  leaf-list ll1 {
    type string;
    description "Leaf List 1";
  }
  leaf-list ll3 {
    type decimal64 {
      fraction-digits 2;
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [
                            Update(Path([PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yschema.DRoot):
        for child in s.children:
            if child.name == 'll1':
                if isinstance(child, yschema.DLeafList):
                    notif_in.take_leaflist(s, child, 'll1', False, [])
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_leaf():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  leaf l1 {
    type string;
    description "Leaf 1";
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yschema.DRoot):
        for child in s.children:
            if child.name == 'l1':
                if isinstance(child, yschema.DLeaf):
                    notif_in.take_leaf(s, child, 'l1', False, [])
                else:
                    raise Exception('l1 is not DLeaf')
    else:
        raise Exception()

def _test_y1_gnmi_key_from_predicate():
    """A gNMI server may carry a list key only in the path predicate (l2[k1=...]),
    not as a separate update for the key leaf. from_gnmi_notif must still resolve
    the non-optional key leaf from the predicate rather than failing with
    "Cannot find child node". This mirrors what Nokia SR Linux sends."""
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c1 {
    list l2 {
      key "k1";
      leaf k1 {
        type string;
      }
      leaf v1 {
        type string;
      }
    }
  }
}"""

    # Note: there is NO update for .../k1 — the key value lives only in the
    # l2[k1=Key 1] predicate, exactly as SR Linux streams it.
    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0)
                            ],
                           [], False)

    s = yang.compile([y1])
    gd = from_gnmi_notif(s, notif_in)
    src = gd.prsrc()
    testing.assertEqual('Key 1' in src, True)
    testing.assertEqual('Value for v1' in src, True)

def _test_y1_gnmi_multi_key_from_predicate():
    """Both keys of a multi-key list, carried only in the predicate, must resolve."""
    ym = r"""module ym {
  namespace "urn:example:ym";
  prefix ym;

  list l {
    key "a b";
    leaf a { type string; }
    leaf b { type string; }
    leaf v { type string; }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('l', [('a', 'A1'), ('b', 'B1')]), PathElem('v', [])], '', ''), StringValue('val'), 0)
                            ],
                           [], False)

    s = yang.compile([ym])
    gd = from_gnmi_notif(s, notif_in)
    src = gd.prsrc()
    testing.assertEqual('A1' in src, True)
    testing.assertEqual('B1' in src, True)

def _test_y1_gnmi_nested_no_keyleak():
    """A leaf named like the parent list's key, but nested in a container with its
    own update, must keep its own value and not inherit the list key (the fix only
    reads elems[-1], and take_container pushes an empty-keys PathElem)."""
    yn = r"""module yn {
  namespace "urn:example:yn";
  prefix yn;

  list l {
    key "k1";
    leaf k1 { type string; }
    container inner {
      leaf k1 { type string; }
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('l', [('k1', 'OUTER')]), PathElem('inner', []), PathElem('k1', [])], '', ''), StringValue('INNER'), 0)
                            ],
                           [], False)

    s = yang.compile([yn])
    gd = from_gnmi_notif(s, notif_in)
    src = gd.prsrc()
    testing.assertEqual('OUTER' in src, True)
    testing.assertEqual('INNER' in src, True)

def _test_y1_gnmi():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c1 {
    description "Container 1";
    leaf l1 {
      type string;
      description "Leaf 1";
    }
    list l2 {
      key "k1";
      leaf k1 {
        type string;
        description "Key 1";
      }
      leaf v1 {
        type string;
        description "Value 1";
      }
    }
    leaf lrf2 {
      type leafref {
        path "/c1/l2/k1";
      }
    }
    leaf-list ll1 {
      type string;
      description "Leaf List 1";
    }
    leaf-list ll3 {
      type decimal64 {
        fraction-digits 2;
      }
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'Key 1')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])
    gd = from_gnmi_notif(s, notif_in)
    return gd.prsrc()

def _test_y1_gnmi_boolean_key():
    """A boolean list key carried in the predicate (enabled=true) must parse as a
    boolean string rather than raising in try_parse_leaf_value."""
    yb = r"""module yb {
  namespace "urn:example:yb";
  prefix yb;

  list lb {
    key "enabled";
    leaf enabled {
      type boolean;
    }
    leaf v1 {
      type string;
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('lb', [('enabled', 'true')]), PathElem('enabled', [])], '', ''), BoolValue(True), 0),
                            Update(Path([PathElem('lb', [('enabled', 'true')]), PathElem('v1', [])], '', ''), StringValue('x'), 0)
                            ],
                           [], False)

    s = yang.compile([yb])
    gd = from_gnmi_notif(s, notif_in)
    src = gd.prsrc()
    testing.assertEqual('x' in src, True)

import testing

from gnmi.proto import Notification, Update, Path, PathElem
from gnmi.proto import StringValue, DoubleValue, LeafListValue
from gnmi.yang.gnmi import from_gnmi_notif, select_notif_paths

import yang
import yang.gdata
import yang.schema

from yang.data import YangValidationError
from yang.identityref import Identityref, PartialIdentityref
from yang.type import Decimal, Ranges

def _test_select_notif_paths():

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    select_notif_paths(notif_in, 'c1')

def _test_y1_gnmi_take_container():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c1 {
    description "Container 1";
    leaf l1 {
      type string;
      description "Leaf 1";
    }
    list l2 {
      key "k1";
      leaf k1 {
        type string;
        description "Key 1";
      }
      leaf v1 {
        type string;
        description "Value 1";
      }
    }
    leaf lrf2 {
      type leafref {
        path "/c1/l2/k1";
      }
    }
    leaf-list ll1 {
      type string;
      description "Leaf List 1";
    }
    leaf-list ll3 {
      type decimal64 {
        fraction-digits 2;
      }
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yang.schema.DRoot):
        for child in s.children:
            if child.name == 'c1':
                if isinstance(child, yang.schema.DContainer):
                    notif_in.take_container(child, 'c1', False, False, [])
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_list():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  list l2 {
    key "k1";
    leaf k1 {
      type string;
      description "Key 1";
    }
    leaf v1 {
      type string;
      description "Value 1";
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                            [
                            Update(Path([PathElem('l2', [('k1', 'A')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('l2', [('k1', 'A')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yang.schema.DRoot):
        c1_opval: ?(op: ?str, val: ?value) = None
        c1_schema: ?yang.schema.DContainer = None

        for child in s.children:
            if child.name == 'l2':
                if isinstance(child, yang.schema.DList):
                    notif_in.take_list(child, 'l2', False, False, [])
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_leaflist():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  leaf-list ll1 {
    type string;
    description "Leaf List 1";
  }
  leaf-list ll3 {
    type decimal64 {
      fraction-digits 2;
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [
                            Update(Path([PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yang.schema.DRoot):
        for child in s.children:
            if child.name == 'll1':
                if isinstance(child, yang.schema.DLeafList):
                    notif_in.take_leaflist(s, child, 'll1', False, False, [])
                else:
                    raise Exception()
    else:
        raise Exception()

def _test_y1_gnmi_take_leaf():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  leaf l1 {
    type string;
    description "Leaf 1";
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0)
                            ],
                           [], False)

    s = yang.compile([y1])

    if isinstance(s, yang.schema.DRoot):
        for child in s.children:
            if child.name == '11':
                if isinstance(child, yang.schema.DLeaf):
                    notif_in.take_leaf(s, child, 'l1', False, False, [])
                else:
                    raise Exception('l1 is not DLeaf')
    else:
        raise Exception()

def _test_y1_gnmi():
    y1 = r"""module y1 {
  namespace "urn:example:y1";
  prefix y1;

  container c1 {
    description "Container 1";
    leaf l1 {
      type string;
      description "Leaf 1";
    }
    list l2 {
      key "k1";
      leaf k1 {
        type string;
        description "Key 1";
      }
      leaf v1 {
        type string;
        description "Value 1";
      }
    }
    leaf lrf2 {
      type leafref {
        path "/c1/l2/k1";
      }
    }
    leaf-list ll1 {
      type string;
      description "Leaf List 1";
    }
    leaf-list ll3 {
      type decimal64 {
        fraction-digits 2;
      }
    }
  }
}"""

    notif_in = Notification(0, Path([], '', ''),
                           [Update(Path([PathElem('c1', []), PathElem('l1', [])], '', ''), StringValue('Value for l1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('k1', [])], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('l2', [('k1', 'A')]), PathElem('v1', [])], '', ''), StringValue('Value for v1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('lrf2', []) ], '', ''), StringValue('Key 1'), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll1', []) ], '', ''), LeafListValue([StringValue('Item 1'), StringValue('Item 2')]), 0),
                            Update(Path([PathElem('c1', []), PathElem('ll3', []) ], '', ''), LeafListValue([DoubleValue(3.14), DoubleValue(2.72)]), 0)
                            ],
                           [], False)

    s = yang.compile([y1])
    gd = from_gnmi_notif(s, notif_in)
    #return gd.prsrc()
